# ── Required API Keys ──────────────────────────────────────
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NewsAPI (free tier): https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# HuggingFace (for FinBERT sentiment): https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_token_here

# ── Optional tuning ─────────────────────────────────────────
# LLM model (default: models/gemini-2.5-flash-lite)
GEMINI_MODEL=models/gemini-2.5-flash-lite

# Score weights (must sum to 1.0)
WEIGHT_ALGO=0.5
WEIGHT_SENT=0.2
WEIGHT_LLM=0.3

# HTTP timeout in seconds
HTTP_TIMEOUT=12

# Concurrent Gemini workers
THREADPOOL_MAX_WORKERS=8
